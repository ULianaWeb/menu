@model menu.Models.Dish

<h2>Create Dish</h2>

<form asp-action="Create" method="post">

    <div>
        <label>Name</label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div>
        <label>Description</label>
        <input asp-for="Description" class="form-control" />
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <div>
        <label>Price</label>
        <input asp-for="Price" type="number" class="form-control" />
        <span asp-validation-for="Price" class="text-danger"></span>
    </div>

    <div>
        <label>Category</label>
        <input asp-for="Category" class="form-control" />
        <span asp-validation-for="Category" class="text-danger"></span>
    </div>

    <div>
        <label>Cooking Time (minutes)</label>
        <input asp-for="CookingTimeMinutes" class="form-control" />
        <span asp-validation-for="CookingTimeMinutes" class="text-danger"></span>
    </div>

    <div>
        <label>Calories</label>
        <input asp-for="Calories" class="form-control" />
        <span asp-validation-for="Calories" class="text-danger"></span>
    </div>

    <h4>Ingredients</h4>

    @foreach (var ing in (List<menu.Models.Ingredient>)ViewBag.Ingredients)
    {
        <div>
            <input type="checkbox" name="selectedIngredients" value="@ing.Id" />
            <label>@ing.Name</label>
        </div>
    }

    <br />

    <button type="submit">Save</button>

</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

<script>
    function createDraft() {
        const dish = {
            name: document.querySelector('[name="Name"]').value,
            description: document.querySelector('[name="Description"]').value,
            price: document.querySelector('[name="Price"]').value || 0,
            CookingTimeMinutes: document.querySelector('[name="CookingTimeMinutes"]').value || 0,
            category: document.querySelector('[name="Category"]').value,
            calories: document.querySelector('[name="Calories"]').value || 0
        };

        fetch('/Dishes/CreateDraft', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify(dish)
        });
    }

    document.querySelectorAll('input').forEach(el => {
        el.addEventListener('input', createDraft);
    });
</script>