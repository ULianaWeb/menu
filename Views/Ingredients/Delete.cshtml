@model menu.Models.Ingredient

@{
    ViewData["Title"] = "Delete Ingredient";
}

<h1>Delete Ingredient</h1>

<h4>Are you sure you want to delete this ingredient?</h4>

<div>
    <dl class="row">
        <dt class="col-sm-2">Name</dt>
        <dd class="col-sm-10">@Model.Name</dd>

        <dt class="col-sm-2">Unit</dt>
        <dd class="col-sm-10">@Model.Unit</dd>

        <dt class="col-sm-2">Calories</dt>
        <dd class="col-sm-10">@Model.Calories</dd>
    </dl>
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a class="btn btn-secondary" href="@Url.Action("Index")">Back to List</a>
</form>