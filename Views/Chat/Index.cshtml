@using Microsoft.AspNetCore.Identity
@using menu.Areas.Identity.Data
@inject UserManager<menuUser> UserManager
@{
    ViewData["Title"] = "Chat";
}

<div class="container mt-3">
    <div class="row">
        <div class="col-12">
            <h3>Чат підтримки</h3>
        </div>
    </div>

    <div class="row mt-3">
        <div class="col-md-4">
            <div class="card">
                <div class="card-header">
                    <strong>Співрозмовники</strong>
                </div>
                <div class="card-body p-2">
                    <select id="userSelect" class="form-select mb-2">
                        <option value="">Загальний чат (всі)</option>
                    </select>

                    <div class="list-group" id="usersListContainer" style="max-height:60vh; overflow:auto;">
                        <!-- Додатково можна рендерити список користувачів тут (JS додає опції) -->
                    </div>
                </div>
                <div class="card-footer small text-muted">Оберіть користувача для приватної розмови</div>
            </div>
        </div>

        <div class="col-md-8 d-flex flex-column">
            <div class="card flex-grow-1">
                <div class="card-header">
                    <strong id="chatHeader">Загальний чат</strong>
                </div>
                <div class="card-body p-3" id="messagesList" style="background:#f8f9fa; overflow:auto; height:60vh;">
                    <!-- Повідомлення -->
                </div>
                <div class="card-footer">
                    <div class="mb-2">
                        <textarea id="messageInput" class="form-control" rows="2" placeholder="Напишіть повідомлення..."></textarea>
                    </div>
                    <div class="d-flex gap-2">
                        <div class="flex-grow-1">
                            <div class="input-group">
                                <input type="file" id="fileInput" class="form-control" />
                                <button id="sendFileBtn" class="btn btn-outline-primary" type="button">Надіслати файл</button>
                            </div>
                        </div>
                        <div class="d-flex flex-column">
                            <button id="sendBtn" class="btn btn-primary mb-2" type="button">Надіслати</button>
                            <button id="clearBtn" class="btn btn-secondary" type="button">Очистити</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.0/signalr.min.js"></script>
    <script src="~/js/chat.js"></script>
    <script>
        // Коротка логіка для оновлення заголовка чату при виборі користувача
        document.addEventListener("DOMContentLoaded", function () {
        const userSelect = document.getElementById("userSelect");
        const chatHeader = document.getElementById("chatHeader");
        userSelect.addEventListener("change", function () {
        const selectedText = userSelect.options[userSelect.selectedIndex].text;
        if (!userSelect.value) {
        chatHeader.textContent = "Загальний чат";
        } else {
        chatHeader.textContent = "Чат з: " + selectedText;
        }
        });

        const clearBtn = document.getElementById("clearBtn");
        clearBtn.addEventListener("click", function () {
        document.getElementById("messageInput").value = "";
        document.getElementById("fileInput").value = "";
        });
        });
    </script>
}
